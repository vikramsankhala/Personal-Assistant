# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vpa
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/vpa

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Anthropic (cloud - claude.ai)
ANTHROPIC_API_KEY=

# Groq (cloud - free at groq.com)
GROQ_API_KEY=

# PyAnnote (HuggingFace token required for diarization models)
HF_TOKEN=your_huggingface_token

# Hugging Face Inference API (for AI features)
HUGGINGFACE_API_TOKEN=your_huggingface_api_token

# Chroma
CHROMA_PERSIST_DIR=./data/chroma

# App
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true
LOG_LEVEL=INFO

# Optional: PII Redaction
PII_REDACTION_ENABLED=true
